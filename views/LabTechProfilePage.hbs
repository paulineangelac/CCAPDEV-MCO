<!DOCTYPE html>
<html lang="en">

<head>
    <!-- LAB TECHNICIAN PROFILE PAGE
  - Displays labtech's profile information (name, username, email, bio, profile pic)
  - Allows labtech to edit their bio and profile picture
  - Reuses StudentProfile.css and StudentProfile.js from student profile

  Main features:
  - Shared navbar + Bootstrap Offcanvas profile sidebar
  - Profile picture upload via /upload-profile-pic (multer)
  - Bio editing handled by editBio() from StudentProfile.js
  - JS: StudentProfile.js handles bio edit toggle and save via /update-bio -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lab Technician Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- StudentDashboardPage CSS: navbar styling -->
    <link rel="stylesheet" href="/css/StudentDashboardPage.css" />
    <!-- StudentProfile CSS: profile layout, bio box, profile pic styling -->
    <link rel="stylesheet" href="/css/StudentProfile.css">
</head>

<body>

    <header class="app-navbar">
        <div class="nav-inner">

            <a class="brand" href="/labtechdashboard-page">
                <span class="brand-logo" aria-hidden="true"></span>
                <span>Lab Reservation</span>
            </a>

            <!--navbar search-->
            <div class="flex-grow-1" role="search" style="max-width: 420px;">
                <div class="nav-search">
                    <input id="userSearch" class="navbar-search-input" type="search" placeholder="Search Users..."
                        autocomplete="off" aria-expanded="false" aria-controls="userSearchResults" />
                    <button class="nav-search-btn" type="button" aria-label="Search">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </div>
            <!-- right side of navbar: profile/menu-->
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <div id="topRightProfile">
                    <button class="profile-chip profile-trigger" type="button" data-bs-toggle="offcanvas"
                        data-bs-target="#profileSidebar" aria-controls="profileSidebar" title="Open menu">
                        <img class="avatar" src="../pictures/temp.jpeg" alt="Profile picture" />
                        <span class="d-flex flex-column lh-2">
                            <span class="fw-bold" style="font-size:13px; color: var(--navy);">{{lname}}, {{fname}}</span>
                            <span class="muted" style="font-size:11px;">{{status}}</span>
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <div class="main-container">
        <header class="profile-pic-header">
            <div id="profile-pic-div">
                <img id="profile-pic" src="{{#if currentUser.profilePic}}{{currentUser.profilePic}}{{else}}/pictures/temp.jpeg{{/if}}" alt="Profile Picture">
                <footer id="input-footer">
                    <form action="/upload-profile-pic" method="POST" enctype="multipart/form-data">
                        <label for="upload-profile-pic" class="upload-button">Edit Profile Picture</label>
                        <input
                            type="file"
                            id="upload-profile-pic"
                            name="profilePic"
                            accept="image/*"
                            hidden
                            onchange="this.form.submit()">
                    </form>
                    <p><i>Suggested: 200x200 pixels</i></p>
                </footer>
            </div>
            <div id="student-information-div">
                <h1>{{currentUser.lname}}, {{currentUser.fname}}</h1>
                <p><strong>Username:</strong> {{currentUser.username}}</p>
                <p><strong>Email:</strong> {{currentUser.email}}</p>

            </div>
            <div id="main-bio-box">
                <strong>Bio:</strong>
                <div id="bio-box">
                    <p id="profile-bio">{{currentUser.bio}}</p>
                </div>
                <footer id="edit-profile-bio">
                    <button id="bio-btn" onclick="editBio()">Edit Bio</button>
                </footer>
            </div>

        </header>



        <footer>
            <a href="/logout" id="logout-btn">Logout</a>
        </footer>
    </div>

    <!--sidebar-->
    <div class="offcanvas offcanvas-end sidebar border-0 shadow" tabindex="-1" id="profileSidebar">

        <div class="sidebar-top d-flex justify-content-between align-items-start p-4">
            <div class="text-white">
                <div id="sidebar-fullname" class="fw-bold fs-5 lh-sm">{{lname}}, {{fname}}</div>
                <div id="sidebar-usertype" class="small opacity-75">{{status}}</div>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>

        <div class="offcanvas-body d-flex flex-column p-3">
            <nav class="nav nav-pills flex-column gap-2 mb-auto">
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/labtechdashboard-page">
                    Dashboard
                </a>
                <a class="nav-link text-white active-green shadow-sm" href="/labtechprofile-page">
                    View Profile
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/faqs-page">
                    FAQs
                </a>
            </nav>
            <a href="/logout" class="btn btn-dark border-0 opacity-75 w-100 py-2 rounded-3 mt-4">
                Logout
            </a>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/StudentProfile.js"></script>
    <script src="/js/Logout.js"></script>
</body>

</html>