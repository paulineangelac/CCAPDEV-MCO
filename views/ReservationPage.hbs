<!DOCTYPE html>
<html lang="en">

<head>
    <!-- RESERVATION / SEAT SELECTION PAGE
  - Lets students choose a lab/date/time and select an available seat
  - Shows a seat map (available vs reserved vs selected)
  - Displays reservation details summary (lab/date/time/seat)
  - Allows anonymous reservation option (checkbox)
  - Confirms reservation (button enabled only when seat is selected)

  Main features:
  - Shared navbar + Bootstrap Offcanvas profile sidebar
  - Filter form (lab/date/time) using Bootstrap grid + form controls
  - Seat map grid (buttons) with reserved/selected states
  - Sticky reservation details panel (right column)
  - JS: handles seat selection + updates detail panel + confirm button  -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lab Reservation - Seat Selection</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="../css/StudentDashboardPage.css" />
    <!-- ReservationPage CSS: seat map layout + seat state colors (available/reserved/selected) + sidebar styling -->
    <link rel="stylesheet" href="../css/ReservationPage.css" />
</head>

<body>
    <!--Navigation bar reused from student dashbaord-->
    <header class="app-navbar">
        <div class="nav-inner">

            <a class="brand" href="../src/IndexPage.html">
                <span class="brand-logo" aria-hidden="true"></span>
                <span>Lab Reservation</span>
            </a>

            <!--navbar search-->
            <div class="flex-grow-1" role="search" style="max-width: 420px;">
                <div class="nav-search">
                    <input id="userSearch" class="navbar-search-input" type="search" placeholder="Search Users..."
                        autocomplete="off" aria-expanded="false" aria-controls="userSearchResults" />
                    <button onclick="searchUser()" class="nav-search-btn" type="button" aria-label="Search">
                        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" fill="none" />
                            <line x1="16.65" y1="16.65" x2="21" y2="21" stroke="currentColor" stroke-width="2" />
                        </svg>
                    </button>
                </div>
            </div>
            <!--right side of navbar: profile/menu-->
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <div id="topRightProfile">
                    <button class="profile-chip profile-trigger" type="button" data-bs-toggle="offcanvas"
                        data-bs-target="#profileSidebar" aria-controls="profileSidebar" title="Open menu">
                        <img class="avatar" src="../pictures/temp.jpeg" alt="Profile picture" />
                        <span class="d-flex flex-column lh-2">
                            <span id="fullname" class="fw-bold" style="font-size:13px; color: var(--navy);">{{lname}}, {{fname}}</span>
                            <span id="type" class="muted" style="font-size:11px;">{{status}}</span>
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <main class="container-xl py-3">
        <!--FILTER FORM 
            Currently used as a UI filter (Phase 1).
            Bootstrap used:
            - row + col-* for responsive form layout
            - g-3 for consistent spacing between fields
            - form-select / form-control for consistent styling -->


        <!-- PAGE LAYOUT: 
            Bootstrap grid layout:
            - Left column (col-lg-8): seat map
            - Right column (col-lg-4): reservation details panel
            Responsive:
            - stacks vertically on small screens (col-12) -->
        <div class="row g-4 mt-4">
            <!--SEAT MAP:
                Seat map is displayed as a grid of buttons.
                Each button represents a seat and has:
                    - data-seat="A1" etc. used by JS to know which seat was clicked
                    Reserved seats:
                    - have class "is-reserved"
                    - are disabled so user cannot select them
                Legend shows meaning of colors/states (available, reserved, selected) -->
            <section class="col-12 col-lg-8">
                <div class="ui-card seatmap-card">
                    <div class="seatmap-top">
                        <h3 class="fs-3 fw-bold text-navy mb-3">Seat Map</h3>

                        <!--legend for the map -->
                        <div class="seat-legend">
                            <span class="legend-item">
                                <span class="legend-swatch"></span> Available
                            </span>
                            <span class="legend-item">
                                <span class="legend-swatch legend-selected"></span> Selected
                            </span>
                        </div>
                    </div>

                    <!--seat selection (hardcoded for now)-->
                    <!-- Seat grid container:
                    - JS attaches click listeners to .lab-seat buttons -->
                    <div id="seatGrid" class="seat-grid" aria-label="Seat map">
                        <!--CREATE SEAT BUTTONS HERE-->
                    </div>
                </div>
            </section>

            <!--RESERVATION DETAILS:
            Summary panel showing:
            - Selected Lab / Date / Time (placeholder text for Phase 1)
            - Selected seat (updated by JS when a seat button is clicked)
            - Anonymous option (checkbox)
            - Confirm button (disabled until a seat is selected)
            Bootstrap used:
            - sticky-top keeps this panel visible while scrolling on larger screens -->
            <aside class="col-12 col-lg-4">
                <div class="ui-card sticky-top reservation-sidebar">
                    <h3 class="fs-3 fw-bold text-navy mb-3">Reservation Details</h3>
                    <form action="/reserve" method="POST">
                        <div class="detail-row">
                        <span class="detail-label">
                            <span class="detail-icon" aria-hidden="true"><i class="bi bi-pc-display"></i></span> Lab
                        </span>
                        <select required id="lab-select" name="roomNumber" class="form-select">
                            <option value="">--Select a Room--</option>
                            {{#each rooms}}
                                {{!-- Optional: Only show rooms that are marked as available --}}
                                {{#if this.isAvailable}}
                                    <option value="{{this.roomNumber}}">{{this.roomCode}}</option>
                                {{/if}}
                            {{/each}}
                        </select>
                        
                        </div>

                        <div class="detail-row">
                            <span class="detail-label">
                                <span class="detail-icon" aria-hidden="true"><i class="bi bi-info-circle"></i></span>
                                Selected Seat
                            </span>
                            <select required id="seat-select" name="seat" class="form-select">
                                
                            </select>
                        </div>

                        <div class="detail-row">
                            <span class="detail-label">
                                <span class="detail-icon" aria-hidden="true"><i class="bi bi-calendar"></i></span> Date
                            </span>
                            <input required type="date" id="date-select" name="date" class="form-control">
                        </div>

                        <div class="detail-row">
                            <span class="detail-label">
                                <span class="detail-icon" aria-hidden="true"><i class="bi bi-clock"></i></span> Time
                            </span>
                            <select required id="time-select" name="time" class="form-select">
                                
                            </select>
                        </div>
                        <div class="form-check mt-3">
                            <input class="form-check-input" type="checkbox" value="Anonnymous" id="anonCheck" name="anon">
                            <label class="form-check-label" for="anonCheck">
                                Reserve anonymously
                            </label>
                        </div>

                        <button class="ui-btn btn-primary w-100 mt-3" id="confirmBtn" disabled>
                            Confirm Reservation
                        </button>

                    </form>
                    
                    <p class="muted mt-3 small mb-0 text-center">
                        Availability is updated periodically. Reserved seats show reservee names unless anonymously
                        booked.
                    </p>
                </div>
            </aside>
        </div>
    </main>

    <!--sidebar-->
     <!--PROFILE SIDEBAR: 
        Bootstrap Offcanvas component used as the student menu sidebar, 
        contains navigation links and logout button. -->
    <div class="offcanvas offcanvas-end sidebar border-0 shadow" tabindex="-1" id="profileSidebar">

        <div class="sidebar-top d-flex justify-content-between align-items-start p-4">
            <div class="text-white">
                <div id="sidebar-fullname" class="fw-bold fs-5 lh-sm">{{lname}}, {{fname}}</div>
                <div id="sidebar-usertype" class="small opacity-75">{{status}}</div>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>

        <div class="offcanvas-body d-flex flex-column p-3">
            <nav class="nav nav-pills flex-column gap-2 mb-auto">
                <a class="nav-link text-white active-green shadow-sm" href="/studentdashboard-page">
                    Dashboard
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/reservation-page">
                    Reserve A Seat
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/studentprofile-page">
                    View Profile
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/faqs-page">
                    FAQs
                </a>
            </nav>
            <a href="/logout-page">
                <button class="btn btn-dark border-0 opacity-75 w-100 py-2 rounded-3 mt-4">
                    Logout
                </button></a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="../js/ReservationPage.js"></script>
    <script src="../js/StudentDashboardPage.js"></script>
</body>

</html>