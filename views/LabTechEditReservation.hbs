<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lab Reservation - Seat Selection</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="../css/LabTechDashboardPage.css" />
    <link rel="stylesheet" href="../css/LabTechReservationPage.css" />
</head>

<body>
    <!--navigation bar-->
    <header class="app-navbar">
        <div class="nav-inner">

        <a class="brand" href="/labtechdashboard-page">
            <span class="brand-logo" aria-hidden="true"></span>
            <span>Lab Reservation</span>
        </a>

            <!--right side of navbar: profile/menu-->
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <div id="topRightProfile">
                    <button class="profile-chip profile-trigger" type="button" data-bs-toggle="offcanvas"
                        data-bs-target="#profileSidebar" aria-controls="profileSidebar" title="Open menu">
                        <img class="avatar" src="/pictures/temp.jpeg" alt="Profile picture" />
                        <span class="d-flex flex-column lh-2">
                            <span class="fw-bold" style="font-size:13px; color: var(--navy);">{{lname}}, {{fname}}</span>
                            <span class="text-muted" style="font-size:11px;">{{status}}</span>
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <main class="container-xl py-3">


        <section class="hero-card ui-card mt-1">
            <div class="row g-3 align-items-end">
                <div class="col-3">
                    <label for="username-select" class="form-label fw-bold text-navy">Choose Student</label>
                    <select id="username-select" class="form-select">
                        <option value="">-- Select a Student --</option>
                    </select>
                </div>
                <div class="col-3">
                    <label for="lab-select" class="form-label fw-bold text-navy">Laboratory</label>
                    <select id="lab-select" class="form-select">
                        <option value="">Select Laboratory</option>
                    </select>
                </div>
                <div class="col-3">
                    <label for="date-select" class="form-label fw-bold text-navy">Date</label>
                    <select id="date-select" class="form-select">
                        <option value="">Select Date</option>
                    </select>
                </div>
                <div class="col-2">
                    <label for="time-select" class="form-label fw-bold text-navy">Time</label>
                    <select id="time-select" class="form-select">
                        <option value="">Select Time</option>
                    </select>
                </div>
                <div class="col-auto">
                    <button type="button" id="findSeatsBtn" class="btn btn-success px-4 py-2 fw-semibold">
                        Find Seats
                    </button>
                </div>
            </div>
        </section>



        <h1 class="fs-1 fw-bold text-navy mb-3 mt-5">Editing Reservation</h1>

        <div class="row g-4 mt-0">
            <!--seat map -->
            <section class="col-12 col-lg-8">
                <div class="ui-card seatmap-card">
                    <div class="seatmap-top">
                        <h3 class="fs-3 fw-bold text-navy mb-3">Seat Map</h3>
                        <div class="seat-legend">
                            <span class="legend-item">
                                <span class="legend-swatch" style="background-color:#E3F2FD;"></span> Previous Seat
                            </span>
                            <span class="legend-item">
                                <span class="legend-swatch"></span> Available
                            </span>
                            <span class="legend-item">
                                <span class="legend-swatch legend-reserved"></span> Reserved
                            </span>
                            <span class="legend-item">
                                <span class="legend-swatch legend-selected"></span> Selected
                            </span>
                        </div>
                    </div>
                    <!--seat selection populated by JS-->
                    <div id="seatGrid" class="seat-grid" aria-label="Seat map">
                        <!--seats loaded dynamically-->
                    </div>
                </div>
            </section>

            <!-- reservation details -->
            <aside class="col-12 col-lg-4">
                <div class="ui-card sticky-top reservation-sidebar">
                    <h3 class="fs-3 fw-bold text-navy mb-3">Reservation Details</h3>

                    <div class="detail-row">
                        <span class="detail-label">
                            <span class="detail-icon" aria-hidden="true"><i class="bi bi-pc-display"></i></span> Lab
                        </span>
                        <span class="detail-value" id="displayLab">—</span>
                    </div>

                    <div class="detail-row">
                        <span class="detail-label">
                            <span class="detail-icon" aria-hidden="true"><i class="bi bi-calendar"></i></span> Date
                        </span>
                        <span class="detail-value" id="displayDate">—</span>
                    </div>

                    <div class="detail-row">
                        <span class="detail-label">
                            <span class="detail-icon" aria-hidden="true"><i class="bi bi-clock"></i></span> Time
                        </span>
                        <span class="detail-value" id="displayTime">—</span>
                    </div>

                    <div class="detail-row">
                        <span class="detail-label">
                            <span class="detail-icon" aria-hidden="true"><i class="bi bi-info-circle"></i></span>
                            Selected Seat
                        </span>
                        <select id="seat-select" class="form-select" style="width:155px;">
                            <option value="">--Select a Seat--</option>
                        </select>
                    </div>


                    <button class="ui-btn btn-primary w-100 mt-3" id="confirmBtn" disabled>
                        Confirm Changes
                    </button>

                    <button class="ui-btn btn-cancel w-100 mt-3" id="cancelBtn">
                        Cancel
                    </button>

                    <p class="muted mt-3 small mb-0 text-center">
                        Availability is updated periodically. Reserved seats show reservee names unless anonymously
                        booked.
                    </p>
                </div>
            </aside>
        </div>
    </main>

    <!--sidebar-->
    <div class="offcanvas offcanvas-end sidebar border-0 shadow" tabindex="-1" id="profileSidebar">

        <div class="sidebar-top d-flex justify-content-between align-items-start p-4">
            <div class="text-white">
                <div id="sidebar-fullname" class="fw-bold fs-5 lh-sm">{{lname}}, {{fname}}</div>
                <div id="sidebar-usertype" class="small opacity-75">{{status}}</div>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>

        <div class="offcanvas-body d-flex flex-column p-3">
            <nav class="nav nav-pills flex-column gap-2 mb-auto">
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/labtechdashboard-page">
                    Dashboard
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/labtechprofile-page">
                    View Profile
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/faqs-page">
                    FAQs
                </a>
            </nav>
            <a href="/logout" class="btn btn-dark border-0 opacity-75 w-100 py-2 rounded-3 mt-4">
                Logout
            </a>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="../js/LabTechReservationPage.js"></script>
</body>

</html>