<!DOCTYPE html>
<html lang="en">

<head>
    <!-- EDIT RESERVATION PAGE
    - This page is the same as Reservation.html but specifically for modifying an existing reservation.
        Unlike ReservationPage.html, this page assumes the user already has
        a confirmed booking and is selecting a new seat. -->

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lab Reservation - Seat Selection</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="../css/StudentDashboardPage.css" />
    <!-- ReservationPage.css: page-specific styles (seat map grid, seat states, reservation sidebar) -->
    <link rel="stylesheet" href="../css/ReservationPage.css" />
</head>

<body>
    <!--navigation bar (reused)-->
    <header class="app-navbar">
        <div class="nav-inner">

            <a class="brand" href="/studentdashboard-page">
                <span class="brand-logo" aria-hidden="true"></span>
                <span>Lab Reservation</span>
            </a>

            <!--navbar search-->
            <div class="flex-grow-1" role="search" style="max-width: 420px;">
                <div class="nav-search">
                    <input id="userSearch" class="navbar-search-input" type="search" placeholder="Search Users..."
                        autocomplete="off" aria-expanded="false" aria-controls="userSearchResults" />
                    <button class="nav-search-btn" type="button" aria-label="Search">
                        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" fill="none" />
                            <line x1="16.65" y1="16.65" x2="21" y2="21" stroke="currentColor" stroke-width="2" />
                        </svg>
                    </button>
                </div>
            </div>

            <!--right side of navbar: profile/menu-->
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <div id="topRightProfile">
                    <button class="profile-chip profile-trigger" type="button" data-bs-toggle="offcanvas"
                        data-bs-target="#profileSidebar" aria-controls="profileSidebar" title="Open menu">
                        <img class="avatar" src="../pictures/temp.jpeg" alt="Profile picture" />
                        <span class="d-flex flex-column lh-2">
                            <span class="fw-bold" style="font-size:13px; color: var(--navy);">{{lname}}, {{fname}}</span>
                            <span class="text-muted" style="font-size:11px;">{{status}}</span>
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <main class="container-xl py-3">

        <h1 class="fs-1 fw-bold text-navy mb-3 mt-5">Editing Reservation</h1>

        <div class="row g-4 mt-0">

            <!--seat map -->
            <section class="col-12 col-lg-8">
                <div class="ui-card seatmap-card">
                    <div class="seatmap-top">
                        <h3 class="fs-3 fw-bold text-navy mb-3">Seat Map</h3>

                        <!--legend for the map -->
                        <!--added a Previous Seat indicator using the .is-current class 
                            to visually marks the seat originally reserved by the student. -->
                        <div class="seat-legend">
                            <span class="legend-item">
                                <span class="legend-swatch legend-current"></span> Previous Seat
                            </span>
                            <span class="legend-item">
                                <span class="legend-swatch legend-selected"></span> Selected
                            </span>
                        </div>
                    </div>

                    <!--seat selection (dynamic)-->
                    <div id="seatGrid" class="seat-grid" aria-label="Seat map">
                        {{!-- Dynamically generate seats from room info --}}
                    </div>
                </div>
            </section>

            <!-- reservation details -->
            <aside class="col-12 col-lg-4">
                <div class="ui-card sticky-top reservation-sidebar">
                    <h3 class="fs-3 fw-bold text-navy mb-3">Reservation Details</h3>

                    <form method="POST" action="/edit/{{booking._id}}">
                        <div class="detail-row">
                            <span class="detail-label">
                                <span class="detail-icon" aria-hidden="true"><i class="bi bi-pc-display"></i></span> Lab
                            </span>
                            <select required id="lab-select" name="roomNumber" class="form-select">
                                <option value="">--Select a Room--</option>
                                {{#each rooms}}
                                    {{#if this.isAvailable}}
                                        <option value="{{this.roomNumber}}" {{#if this.isSelected}}selected{{/if}}>
                                            {{this.roomCode}}
                                        </option>
                                    {{/if}}
                                {{/each}}
                            </select>
                        </div>

                        <div class="detail-row">
                            <span class="detail-label">
                                <span class="detail-icon" aria-hidden="true"><i class="bi bi-info-circle"></i></span>
                                Selected Seat
                            </span>
                            <select required id="seat-select" name="seat" class="form-select">
                            </select>
                        </div>

                        <div class="detail-row">
                            <span class="detail-label">
                                <span class="detail-icon" aria-hidden="true"><i class="bi bi-calendar"></i></span> Date
                            </span>
                            <input required type="date" id="date-select" name="date" class="form-control" value="{{booking.date}}">
                        </div>

                        <div class="detail-row">
                            <span class="detail-label">
                                <span class="detail-icon" aria-hidden="true"><i class="bi bi-clock"></i></span> Time
                            </span>
                            <select required id="time-select" name="time" class="form-select">
                                <option value="">--Select a Time--</option>
                                <option value="7:30 - 9:00">7:30 - 9:00</option>
                                <option value="9:15 - 10:45">9:15 - 10:45</option>
                                <option value="11:00 - 12:30">11:00 - 12:30</option>
                                <option value="12:45 - 2:15">12:45 - 2:15</option>
                                <option value="2:30 - 4:00">2:30 - 4:00</option>
                                <option value="4:15 - 5:45">4:15 - 5:45</option>
                                <option value="6:00 - 7:30">6:00 - 7:30</option>
                            </select>
                        </div>

                        <div class="form-check mt-3">
                            <input class="form-check-input" type="checkbox" value="" id="anonCheck">
                            <label class="form-check-label" for="anonCheck">
                                Reserve anonymously
                            </label>
                        </div>

                        <!--changed from confirm reservation-->
                        <button class="ui-btn btn-primary w-100 mt-3" id="confirmBtn" type="submit">
                            Confirm Changes
                        </button>
                    </form>

                    <p class="muted mt-3 small mb-0 text-center">
                        Availability is updated periodically. Reserved seats show reservee names unless anonymously booked.
                    </p>
                </div>
            </aside>
        </div>
    </main>

    <!--sidebar-->
    <div class="offcanvas offcanvas-end sidebar border-0 shadow" tabindex="-1" id="profileSidebar">
        <div class="sidebar-top d-flex justify-content-between align-items-start p-4">
            <div class="text-white">
                <div class="fw-bold fs-5 lh-sm">{{lname}}, {{fname}}</div>
                <div class="small opacity-75">{{status}}</div>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>

        <div class="offcanvas-body d-flex flex-column p-3">
            <nav class="nav nav-pills flex-column gap-2">
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/studentdashboard-page">
                    Dashboard
                </a>
                <a class="nav-link text-white active-green shadow-sm" href="/reservation-page">
                    Reserve A Seat
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/studentprofile-page">
                    View Profile
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/my-reservations">
                    My Reservations
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/faqs-page">
                    FAQs
                </a>
            </nav>

            <button class="btn btn-dark border-0 opacity-75 w-100 py-2 rounded-3 mt-4" id="logoutBtn">
                Logout
            </button>
        </div>
    </div>

    <script>
        window.editReservationData = {
            booking: {{{bookingJson}}},
            rooms: {{{roomsJson}}}
        };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/EditReservation.js"></script>
</body>

</html>