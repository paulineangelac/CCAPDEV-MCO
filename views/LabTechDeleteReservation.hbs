<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Delete Reservation</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="../css/LabTechDashboardPage.css" />
    <link rel="stylesheet" href="../css/LabTechReservationPage.css" />
</head>

<body>
    <!--navigation bar-->
    <header class="app-navbar">
        <div class="nav-inner">

            <a class="brand" href="../src/IndexPage.html">
                <span class="brand-logo" aria-hidden="true"></span>
                <span>Lab Reservation</span>
            </a>

            <!--navbar search-->
            <div class="flex-grow-1" role="search" style="max-width: 420px;">
                <div class="nav-search">
                    <input id="userSearch" class="navbar-search-input" type="search" placeholder="Search Users..."
                        autocomplete="off" aria-expanded="false" aria-controls="userSearchResults" />
                    <button class="nav-search-btn" type="button" aria-label="Search">
                        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" fill="none" />
                            <line x1="16.65" y1="16.65" x2="21" y2="21" stroke="currentColor" stroke-width="2" />
                        </svg>
                    </button>
                </div>
            </div>
            <!--right side of navbar: profile/menu-->
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <div id="topRightProfile">
                    <button class="profile-chip profile-trigger" type="button" data-bs-toggle="offcanvas"
                        data-bs-target="#profileSidebar" aria-controls="profileSidebar" title="Open menu">
                        <img class="avatar" src="/pictures/temp.jpeg" alt="Profile picture" />
                        <span class="d-flex flex-column lh-2">
                            <span class="fw-bold" style="font-size:13px; color: var(--navy);">{{lname}}, {{fname}}</span>
                            <span class="text-muted" style="font-size:11px;">{{status}}</span>
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <main class="container-xl py-3">

        <section class="hero-card ui-card mt-1">
            <div class="row g-3 align-items-end">
                <div class="col-3">
                    <label for="student-select" class="form-label fw-bold text-navy">Choose Student</label>
                    <select id="student-select" class="form-select">
                        <option value="">-- Select a Student --</option>
                    </select>
                </div>
                <div class="col-3">
                    <label for="date-select" class="form-label fw-bold text-navy">Date</label>
                    <select id="date-select" class="form-select" disabled>
                        <option value="">-- Select a Date --</option>
                    </select>
                </div>
                <div class="col-2">
                    <label for="time-select" class="form-label fw-bold text-navy">Time</label>
                    <select id="time-select" class="form-select" disabled>
                        <option value="">-- Select a Time --</option>
                    </select>
                </div>
                <div class="col-2">
                    <label for="lab-display" class="form-label fw-bold text-navy">Laboratory</label>
                    <input type="text" id="lab-display" class="form-control" disabled>
                </div>
                <div class="col-2">
                    <label for="seat-display" class="form-label fw-bold text-navy">Seat</label>
                    <input type="text" id="seat-display" class="form-control" disabled>
                </div>
                <div class="col-auto">
                    <button type="button" id="deleteBtn" class="btn btn-danger px-4 py-2 fw-semibold" disabled>
                        Delete Reservation
                    </button>
                </div>
                <div class="col-auto">
                    <button type="button" id="cancelBtn" class="btn btn-secondary px-4 py-2 fw-semibold d-block">
                        Cancel
                    </button>
                </div>
            </div>
        </section>

    </main>

    <!--sidebar-->
    <div class="offcanvas offcanvas-end sidebar border-0 shadow" tabindex="-1" id="profileSidebar">

        <div class="sidebar-top d-flex justify-content-between align-items-start p-4">
            <div class="text-white">
                <div id="sidebar-fullname" class="fw-bold fs-5 lh-sm">{{lname}}, {{fname}}</div>
                <div id="sidebar-usertype" class="small opacity-75">{{status}}</div>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>

        <div class="offcanvas-body d-flex flex-column p-3">
            <nav class="nav nav-pills flex-column gap-2 mb-auto">
                <a class="nav-link text-white active-green shadow-sm" href="/labtechdashboard-page">
                    Dashboard
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/LabTechProfilePage">
                    View Profile
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="../src/FAQsPage.html">
                    FAQs
                </a>
            </nav>
            <a href="/logout" class="btn btn-dark border-0 opacity-75 w-100 py-2 rounded-3 mt-4">
                Logout
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="../js/LabTechDeleteReservation.js"></script>
</body>

</html>