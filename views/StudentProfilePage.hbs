<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="../css/StudentDashboardPage.css" />
    <link rel="stylesheet" href="../css/StudentProfile.css">
</head>

<body>
    <!-- Header -->
    <header class="app-navbar">
        <div class="nav-inner">

            <a class="brand" href="/studentdashboard-page">
                <span class="brand-logo" aria-hidden="true"></span>
                <span>Lab Reservation</span>
            </a>

            <!--navbar search-->
            <div class="flex-grow-1" role="search" style="max-width: 420px;">
                <div class="nav-search">
                    <input id="userSearch" class="navbar-search-input" type="search" placeholder="Search Users..."
                        autocomplete="off" aria-expanded="false" aria-controls="userSearchResults" />
                    <button onclick="searchUser()" class="nav-search-btn" type="button" aria-label="Search">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
                <div id="userSearchResults" class="search-results"></div>
            </div>

            <!-- right side of navbar: profile/menu-->
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <div id="topRightProfile">
                    <button class="profile-chip profile-trigger" type="button" data-bs-toggle="offcanvas" data-bs-target="#profileSidebar" aria-controls="profileSidebar" title="Open menu">
                        <img class="avatar" src="{{#if currentUser.profilePic}}{{currentUser.profilePic}}{{else}}/pictures/temp.jpeg{{/if}}" alt="Profile picture" />
                        <span class="d-flex flex-column lh-2">
                        <span id="fullname" class="fw-bold" style="font-size:13px; color: var(--navy);">{{currentUser.lname}}, {{currentUser.fname}}</span>
                        <span id="type" class="muted" style="font-size:11px;">{{currentUser.status}}</span>
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Box for the profile box -->
    <div class="main-container">
        <!-- Upper Part of the Profile Div Container -->
        <header class="profile-pic-header">
            <div id="profile-pic-div">
                <img id="profile-pic" src="{{#if currentUser.profilePic}}{{currentUser.profilePic}}{{else}}/pictures/temp.jpeg{{/if}}" alt="Profile Picture">
                <footer id="input-footer">
                    <form action="/upload-profile-pic" method="POST" enctype="multipart/form-data">
                        <label for="upload-profile-pic" class="upload-button">Edit Profile Picture</label>
                        <input
                            type="file"
                            id="upload-profile-pic"
                            name="profilePic"
                            accept="image/*"
                            hidden
                            onchange="this.form.submit()">
                    </form>
                    <p><i>Suggested: 200x200 pixels</i></p>
                </footer>
            </div>

            <!-- Student Information Column -->
            <div id="student-information-div">
                <h1>{{currentUser.lname}}, {{currentUser.fname}}</h1>
                <p><strong>Username:</strong> {{currentUser.username}}</p>
                <p><strong>Email:</strong> {{currentUser.email}}</p>
            </div>

            <!-- Bio Column -->
            <div id="main-bio-box">
                <strong>Bio:</strong>
                <div id="bio-box">
                    <p id="profile-bio">{{currentUser.bio}}</p>
                    <textarea id="bio-textarea" style="display:none;">{{currentUser.bio}}</textarea>
                </div>
                <footer id="edit-profile-bio">
                    <button id="bio-btn" type="button" onclick="editBio()">Edit Bio</button>
                </footer>
            </div>
        </header>

        <!-- List of reservations of the student -->
        <section class="reservations">
            <h2>My Reservations</h2>
            <div class="card" id="scroll-card">
                <div id="booking-list">
                    {{#each bookings}}
                        <div class="booking-card">
                            <div class="booking-header">
                                <span class="booking-lab">{{this.roomNumber}} - {{this.seat}}</span>
                                <span class="status-tag">Confirmed</span>
                            </div>
                            <div class="booking-summary">
                                <p>{{this.date}}, {{this.time}}</p>
                            </div>
                            <div class="booking-footer">
                                <a href="/edit/{{this._id}}" class="btn-details text-decoration-none">
                                    Edit Reservation
                                </a>

                                <form action="/cancel/{{this._id}}" method="POST" style="display:inline;">
                                    <button
                                        type="submit"
                                        class="btn-details"
                                        style="color:Red;"
                                        onclick="return confirm('Are you sure you want to cancel this reservation?')">
                                        Cancel Reservation
                                    </button>
                                </form>
                            </div>
                        </div>
                    {{else}}
                        <div>
                            <p>No upcoming reservations found.</p>
                        </div>
                    {{/each}}
                </div>
            </div>
        </section>

        <!-- Footer for logout button -->
        <footer>
            <a href="/logout-page">
                <button id="logout-btn">Logout</button>
            </a>
        </footer>
    </div>

    <!-- Reused the side panel for pressing profile in the top left -->
    <div class="offcanvas offcanvas-end sidebar border-0 shadow" tabindex="-1" id="profileSidebar">

        <div class="sidebar-top d-flex justify-content-between align-items-start p-4">
            <div class="text-white">
                <div id="sidebar-fullname" class="fw-bold fs-5 lh-sm">{{currentUser.lname}}, {{currentUser.fname}}</div>
                <div id="sidebar-usertype" class="small opacity-75">{{currentUser.status}}</div>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>

        <div class="offcanvas-body d-flex flex-column p-3">
            <nav class="nav nav-pills flex-column gap-2 mb-auto">
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/studentdashboard-page">
                    Dashboard
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/reservation-page">
                    Reserve A Seat
                </a>
                <a class="nav-link text-white active-green shadow-sm" href="/studentprofile-page">
                    View Profile
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/faqs-page">
                    FAQs
                </a>
            </nav>
            <a href="/logout-page">
                <button class="btn btn-dark border-0 opacity-75 w-100 py-2 rounded-3 mt-4" id="logoutBtn">
                    Logout
                </button>
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="../js/StudentProfile.js"></script>
    <script src="../js/Logout.js"></script>
    <script src="../js/StudentDashboardPage.js"></script>
</body>

</html>