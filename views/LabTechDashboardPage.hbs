<!DOCTYPE html>
<html lang="en">

<head>
    <!-- LAB TECHNICIAN DASHBOARD PAGE
  - Main hub for lab technician actions
  - Provides buttons to make, edit, or cancel student reservations
  - Shows ITS updates panel on the right

  Main features:
  - Shared navbar + Bootstrap Offcanvas profile sidebar
  - Action buttons (make/edit/cancel reservation) in left column
  - ITS updates news feed in right column
  - JS: LabTechDashboardPage.js handles navbar interactions -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lab Technician Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- LabTechDashboardPage CSS: navbar, action buttons, news feed styling -->
    <link rel="stylesheet" href="../css/LabTechDashboardPage.css" />
</head>

<body>

    <!--Navigation bar-->
    <header class="app-navbar">
        <div class="nav-inner">

            <a class="brand" href="/labtechdashboard-page">
                <span class="brand-logo" aria-hidden="true"></span>
                <span>Lab Reservation</span>
            </a>

            <!--right side of navbar: profile/menu trigger-->
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <div id="topRightProfile">
                    <!--Profile menu sidebar using bootstrap offcanvas-->
                    <button class="profile-chip profile-trigger" type="button" data-bs-toggle="offcanvas"
                        data-bs-target="#profileSidebar" aria-controls="profileSidebar" title="Open menu">
                        <img class="avatar" src="../pictures/temp.jpeg" alt="Profile picture" />
                        <span class="d-flex flex-column lh-2">
                            <span id="fullname" class="fw-bold" style="font-size:13px; color: var(--navy);">{{lname}},
                                {{fname}}</span>
                            <span id="type" class="muted" style="font-size:11px;">{{status}}</span>
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <main class="container-xl py-3">
        <!-- PAGE LAYOUT:
            Bootstrap grid layout:
            - Left column (col-lg-8): action buttons
            - Right column (col-lg-4): ITS updates feed
            Responsive:
            - stacks vertically on small screens -->
        <div class="row g-4 mt-4">
            <!-- ACTION BUTTONS:
                Three buttons for labtech actions:
                - Make reservation: green, goes to /makereservation-page
                - Edit reservation: gray, goes to /editreservation-page
                - Cancel reservation: red, goes to /deletereservation-page -->
            <section class="col-lg-8">
                <h3 class="fw-bold text-navy">Choose an Option:</h3>
                <a href="/makereservation-page">
                    <button id="makereservationbtn"><strong>Make a reservation for a Student</strong></button>
                </a>

                <a href="/editreservation-page">
                    <button id="makereservationbtn" style="background-color:gray;"><strong>Edit a reservation for a
                            Student</strong></button>
                </a>

                <a href="/deletereservation-page">
                    <button id="deletereservationbtn" style="background-color:red;"><strong>Cancel a reservation for a
                            Student</strong></button>
                </a>
            </section>

            <!-- ITS UPDATES:
                Static news feed showing system updates, urgent alerts, and notices
                Each item has a category tag, date, and short content -->
            <aside class="col-lg-4">

                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h3 class="fw-bold text-navy m-0">ITS Updates</h3>

                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-success">New</span>
                        <a href="#" class="muted small">See all</a>
                    </div>
                </div>

                <div class="news-updates">

                    <!-- ITEM -->
                    <div class="news-item item-blue">
                        <div class="news-meta">
                            <span class="news-category">SYSTEM</span>
                            <span class="news-date">Feb 10</span>
                        </div>
                        <div class="news-content">
                            Gokongwei Wi-Fi Upgrade.
                        </div>
                    </div>

                    <!-- ITEM -->
                    <div class="news-item item-red">
                        <div class="news-meta">
                            <span class="news-category">URGENT</span>
                            <span class="news-date">Jan 29</span>
                        </div>
                        <div class="news-content">
                            Phishing Alert: Check emails.
                        </div>
                    </div>

                    <!-- ITEM -->
                    <div class="news-item item-green">
                        <div class="news-meta">
                            <span class="news-category">NOTICE</span>
                            <span class="news-date">Feb 10</span>
                        </div>
                        <div class="news-content">
                            Lab 402 Aircon Maintenance scheduled for this weekend.
                        </div>
                    </div>

                </div>

            </aside>

        </div>
    </main>

    <!--PROFILE SIDEBAR:
        Bootstrap Offcanvas component used as the labtech menu sidebar,
        contains navigation links and logout button. -->
    <div class="offcanvas offcanvas-end sidebar border-0 shadow" tabindex="-1" id="profileSidebar">

        <div class="sidebar-top d-flex justify-content-between align-items-start p-4">
            <div class="text-white">
                <div id="sidebar-fullname" class="fw-bold fs-5 lh-sm">{{lname}}, {{fname}}</div>
                <div id="sidebar-usertype" class="small opacity-75">{{status}}</div>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>

        <div class="offcanvas-body d-flex flex-column p-3">
            <nav class="nav nav-pills flex-column gap-2 mb-auto">
                <a class="nav-link text-white active-green shadow-sm" href="/labtechdashboard-page">
                    Dashboard
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/labtechprofile-page">
                    View Profile
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/faqs-page">
                    FAQs
                </a>
            </nav>
            <a href="/logout" class="btn btn-dark border-0 opacity-75 w-100 py-2 rounded-3 mt-4">
                Logout
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="../js/LabTechDashboardPage.js"></script>

</body>

</html>