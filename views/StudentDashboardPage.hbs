<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!--  Custom css styles for navbar, cards, tags, colors, and layout overrides -->
    <link rel="stylesheet" href="../css/StudentDashboardPage.css" />
</head>

<body>
    <!--Custom Navigation Bar:
    Contains system branding, search bar, and profile button.
    Profile button triggers the Bootstrap offcanvas sidebar. -->
    <header class="app-navbar">
        <div class="nav-inner">

            <a class="brand" href="../src/IndexPage.hbs">
                <span class="brand-logo" aria-hidden="true"></span>
                <span>Lab Reservation</span>
            </a>

            <!--user search-->
            <div class="flex-grow-1" role="search" style="max-width: 420px;">
                <div class="nav-search">
                    <input id="userSearch" class="navbar-search-input" type="search" placeholder="Search Users..."
                        autocomplete="off" aria-expanded="false" aria-controls="userSearchResults" />
                    <button onclick="searchUser()" class="nav-search-btn" type="button" aria-label="Search">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
                <div id="userSearchResults" class="search-results"></div>
            </div>

            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <div id="topRightProfile">
                    <!--Profile menu sidebar using bootstrap offcanvas-->
                    <button class="profile-chip profile-trigger" type="button" data-bs-toggle="offcanvas"
                        data-bs-target="#profileSidebar" aria-controls="profileSidebar" title="Open menu">
                        <img class="avatar" src="../pictures/temp.jpeg" alt="Profile picture" />
                        <span class="d-flex flex-column lh-2">
                            <span id="fullname" class="fw-bold" style="font-size:13px; color: var(--navy);">{{lname}}, {{fname}}</span>
                            <span id="type" class="muted" style="font-size:11px;">{{status}}</span>
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </header>
    <!-- Main Content wrapper using Bootstrap -->
    <main class="container-xl py-3">
        <!--ITS UPDATES-->
        <section class="announcements-section">
            <div class="section-header d-flex justify-content-between align-items-center mb-3">
                <div class="d-flex align-items-center">
                    <h3 class="fs-5 fw-bold text-navy mb-0">ITS Updates</h3>
                    <span class="badge bg-success ms-3" style="font-size: 10px;">New</span>
                </div>
                <a href="#">See all</a>
            </div>
            <!--mini announcement cards-->
            <div class="d-flex gap-3 flex-wrap">
                <div class="announce-card ui-card d-flex align-items-center gap-2">
                    <span class="announce-tag tag-maintenance">maintenance</span>
                    <span class="announce-title">Gokongwei Hall Wi-Fi Upgrade</span>
                    <span class="announce-date">Feb 10</span>
                </div>
                <div class="announce-card ui-card d-flex align-items-center gap-2">
                    <span class="announce-tag tag-notice">notice</span>
                    <span class="announce-title">Term 2 Software Requests Open</span>
                    <span class="announce-date">Feb 01</span>
                </div>
                <div class="announce-card ui-card d-flex align-items-center gap-2">
                    <span class="announce-tag tag-urgent">urgent</span>
                    <span class="announce-title">Phishing Alert: DLSU Google Workspace</span>
                    <span class="announce-date">Jan 29</span>
                </div>
                <div class="announce-card ui-card d-flex align-items-center gap-2">
                    <span class="announce-tag tag-urgent">urgent</span>
                    <span class="announce-title">Lab 402 Aircon Maintenance</span>
                    <span class="announce-date">Jan 24</span>
                </div>
            </div>
        </section>

        <!--RESERVATION SEARCH 
            Form redirects to ReservationPage.html using GET parameters:
            lab, date, and time are passed in the URL query string. -->
        <section class="hero-card ui-card mt-3">
            <header class="dashboard-header">
                <h1 class="page-title">Find and reserve a lab seat</h1>
                <p class="muted mb-0">Select a laboratory, date and time to secure a slot</p>
            </header>


            <div class="col-12 col-md-auto">
                <a href="/reservation-page" class="btn btn-success px-4 py-2 fw-semibold">
                    Find Seats
                </a>
            </div>
        </section>

        <div class="row g-4 mt-4">

            <!--DASHBOARD LAYOUT 
            Bootstrap grid layout:
            Left: Upcoming Reservations (col-lg-8)
            Right: Recommended Laboratories (col-lg-4) -->
            <section class="col-12 col-lg-8 reservations-column">
                <h3 class="fs-5 fw-bold text-navy mb-3">Upcoming Reservations</h3>

                <div class="ui-card" id="reserve-div">
                    <div id="booking-list" class="d-flex flex-column gap-3">

                        <div class="card" id="scroll-card">
                            <div id="booking-list">
                            {{#each reservations}}
                                <div class="booking-card">
                                    <div class="booking-header">
                                        <span class="booking-lab">{{this.roomNumber}} - {{this.seat}}</span>
                                        <span class="status-tag">Confirmed</span>
                                    </div>
                                    <div class="booking-summary">
                                        <p>{{this.date}}, {{this.time}}</p>
                                    </div>
                                    <div class="booking-footer">
                                        <a href="/edit/{{this._id}}" class="btn-details text-decoration-none">
                                        Edit Reservation
                                        </a>
                                        <button class="btn-details" style="color:Red;">Cancel Reservation</button>
                                    </div>
                                </div>
                            {{else}}
                                <div>
                                    <p>No upcoming reservations found.</p>
                                </div>
                                    
                            {{/each}}    
                            </div>
                        </div>
            </section>

            <!--Reccomended labs for the student -->
            <aside class="col-12 col-lg-4 labs-column">
                <h3 class="fs-5 fw-bold text-navy mb-3">Recommended Laboratories</h3>
               {{#each room}}
                <div id="recommended-rooms">
                    <a href="/reservation-page" class="lab-card ui-card">
                        <div class="lab-card__info">
                            <span class="lab-name">{{this.roomNumber}}</span>
                            <span class="lab-status small">{{this.seatNumbers.length}} Seats Available</span>
                        </div>
                        <span class="chevron">→</span>
                    </a>
                </div>
                {{/each}}
            </aside>
        </div>
    </main>

    <!--PROFILE SIDEBAR: 
        Bootstrap Offcanvas component used as the student menu sidebar, 
        contains navigation links and logout button. -->
    <div class="offcanvas offcanvas-end sidebar border-0 shadow" tabindex="-1" id="profileSidebar">

        <div class="sidebar-top d-flex justify-content-between align-items-start p-4">
            <div class="text-white">
                <div id="sidebar-fullname" class="fw-bold fs-5 lh-sm">{{lname}}, {{fname}}</div>
                <div id="sidebar-usertype" class="small opacity-75">{{status}}</div>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>

        <div class="offcanvas-body d-flex flex-column p-3">
            <nav class="nav nav-pills flex-column gap-2 mb-auto">
                <a class="nav-link text-white active-green shadow-sm" href="/studentdashboard-page">
                    Dashboard
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/reservation-page">
                    Reserve A Seat
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/studentprofile-page">
                    View Profile
                </a>
                <a class="nav-link text-white text-decoration-none hover-opacity" href="/faqs-page">
                    FAQs
                </a>
            </nav>
            <a href="/logout-page">
                <button class="btn btn-dark border-0 opacity-75 w-100 py-2 rounded-3 mt-4">
                    Logout
                </button></a>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="../js/StudentDashboardPage.js"></script>
</body>

</html>