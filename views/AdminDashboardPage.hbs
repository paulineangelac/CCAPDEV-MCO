<!DOCTYPE html>
<html lang="eng"> <!-- NOTE: Should technically be "en" (ISO standard language code) -->

<head>
    <!-- =========================================================
        LAB RESERVATION SYSTEM – ADMIN DASHBOARD PAGE
    ========================================================== -->

    <meta charset="UTF-8">
    <!-- Ensures proper scaling on mobile devices -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Lab Reservation Index Page</title>

    <!-- Custom CSS for admin-specific styling -->
    <link rel="stylesheet" href="../css/AdminDashboardPage.css" />

    <!-- Bootstrap CSS (used for layout system, tabs, forms, responsiveness) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Shared CSS reused across dashboards (code reuse instead of duplication) -->
    <link rel="stylesheet" href="../css/StudentDashboardPage.css" />

    <!-- Bootstrap JS required for interactive components (tabs, offcanvas, dropdowns) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>
    <!-- NAVBAR -->
    <header class="app-navbar">
        <div class="nav-inner">

            <!-- Static link to landing page (not routed dynamically) -->
            <a class="brand" href="">
                <span class="brand-logo" aria-hidden="true"></span>
                <span>Lab Reservation</span>
            </a>

            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <div id="topRightProfile">

                    <!-- 
                        Bootstrap offcanvas trigger:
                        data-bs-toggle connects button to sidebar
                        data-bs-target must match sidebar ID
                    -->
                    <button class="profile-chip profile-trigger" type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#profileSidebar"
                        aria-controls="profileSidebar">

                        <img class="avatar" src="../pictures/temp.jpeg" alt="Profile picture" />

                        <!-- 
                            Handlebars template variables:
                            These values are injected from backend (Express)
                            Example: res.render('AdminDashboardPage', { fname, lname, status })
                        -->
                        <span class="d-flex flex-column lh-2">
                            <span id="fullname" class="fw-bold">
                                {{lname}}, {{fname}}
                            </span>
                            <span id="type" class="muted">
                                {{status}}
                            </span>
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <main class="container">

        <header class="mt-5">
            <h1>Admin Dashboard</h1>
            <p class="muted">
                Create and manage laboratory technician accounts in real time.
            </p>
        </header>

        <!-- 
            Bootstrap Tab System:
            - data-bs-toggle="pill" enables tab switching
            - data-bs-target links to corresponding tab-pane
        -->
        <ul class="nav nav-pills mb-4 admin-tabs" role="tablist">

            <li class="nav-item">
                <button class="nav-link active"
                    data-bs-toggle="pill"
                    data-bs-target="#manage-labtechs">
                    Manage Lab Techs
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link"
                    data-bs-toggle="pill"
                    data-bs-target="#create-labtech">
                    Create Lab Tech
                </button>
            </li>
        </ul>

        <div class="tab-content">

            <!-- ===================== MANAGE TECHNICIANS ===================== -->
            <div class="tab-pane fade show active" id="manage-labtechs">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">All Laboratory Technicians</h5>
                </div>

                <div class="row g-4">

                    <!-- 
                        Handlebars Loop:
                        Iterates over "labtech" array passed from backend.
                        Each item represents one technician object from database.
                        
                        Example backend:
                        res.render('AdminDashboardPage', { labtech: dataFromMongo })
                    -->
                    {{#each labtech}}
                    <div class="col-xl-4 col-md-6 labtech-card">
                        <div class="admin-card d-flex align-items-center">

                            <!-- Static placeholder image (can be replaced with dynamic profile images later) -->
                            <img src="../pictures/temp.jpeg" class="admin-avatar">

                            <div class="ms-3 labtech-info">
                                <!-- Accessing fields from each object -->
                                <h6 class="mb-1 fw-bold">
                                    {{this.fname}}, {{this.lname}}
                                </h6>
                                <p class="mb-0 text-muted small">{{this.email}}</p>
                                <p class="mb-0 text-muted small">
                                    +63{{this.number}}
                                </p>
                            </div>
                        </div>
                    </div>
                    {{/each}}

                    <!-- 
                        If labtech is empty then nothing renders
                        (could be improved with {{else}} for empty state)
                    -->
                </div>
            </div>

            <!-- ===================== CREATE TECHNICIAN ===================== -->
            <div class="tab-pane fade" id="create-labtech">

                <h5 class="fw-bold mb-4">Create Laboratory Technician</h5>

                <div class="card shadow-sm p-4">

                    <!-- 
                        Form submits to Express route:
                        POST /makelabtech
                        
                        Backend should:
                        1. Validate inputs
                        2. Hash password
                        3. Save to MongoDB
                    -->
                    <form method="POST" action="/makelabtech">

                        <div class="row g-3">

                            <!-- Username used for login (must be unique in DB) -->
                            <div class="col-md-6">
                                <label class="form-label">Username</label>
                                <input name="username" type="text" class="form-control" required>
                            </div>

                            <!-- Personal info fields -->
                            <div class="col-md-6">
                                <label class="form-label">First Name</label>
                                <input name="fname" type="text" class="form-control" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Last Name</label>
                                <input name="lname" type="text" class="form-control" required>
                            </div>

                            <!-- Optional contact field (not required) -->
                            <div class="col-md-6">
                                <label class="form-label">Contact Number</label>
                                <input name="number" type="tel" class="form-control">
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Email</label>
                                <input name="email" type="email" class="form-control" required>
                            </div>

                            <!-- 
                                Password fields:
                                - confirm password should be validated in backend
                                - NEVER trust frontend validation alone
                            -->
                            <div class="col-md-6">
                                <label class="form-label">Password</label>
                                <input name="password" type="password" class="form-control" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Confirm Password</label>
                                <input name="confirmpass" type="password" class="form-control" required>
                            </div>

                            <!-- Submit button triggers POST request -->
                            <div class="col-12 text-end">
                                <button type="submit"
                                    id="createLabTechBtn"
                                    class="btn btn-success btn-labtech px-4">
                                    Create Account
                                </button>
                            </div>

                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <!-- ===================== OFFCANVAS SIDEBAR ===================== -->
    <div class="offcanvas offcanvas-end sidebar border-0 shadow"
        tabindex="-1"
        id="profileSidebar">

        <!-- 
            Sidebar content also uses Handlebars variables
            Ensures consistency with navbar user info
        -->
        <div class="sidebar-top d-flex justify-content-between align-items-start p-4">
            <div class="text-white">
                <div class="fw-bold fs-5">
                    {{lname}}, {{fname}}
                </div>
                <div class="small opacity-75">{{status}}</div>
            </div>

            <!-- Closes sidebar using Bootstrap JS -->
            <button type="button"
                class="btn-close btn-close-white"
                data-bs-dismiss="offcanvas">
            </button>
        </div>

        <div class="offcanvas-body d-flex flex-column p-3">

            <!-- Navigation inside sidebar -->
            <nav class="nav nav-pills flex-column gap-2 mb-auto">
                <a class="nav-link text-white active-green shadow-sm"
                    href="AdminDashboardPage.html">
                    Dashboard
                </a>
            </nav>

            <!-- 
                Logout route:
                Should destroy session on backend (req.session.destroy)
            -->
            <a href="/logout">
                <button class="btn btn-dark w-100 mt-4" id="logoutBtn">
                    Logout
                </button>
            </a>
        </div>
    </div>

    <!-- 
        External JS file:
        Used for dynamic behaviors (future enhancements like search/filter)
        Keeps logic separate from HTML (separation of concerns)
    -->
    <script src="../js/AdminDashboardPage.js"></script>
</body>

</html>